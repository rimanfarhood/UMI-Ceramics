@model UmiCeramics.Models.Workshop

@{
ViewData["Title"] = Model.Title;

var bookedSeats = Model.Bookings.Sum(b => b.NumberOfSeats);
var availableSeats = Model.Capacity - bookedSeats;

}

<div class="workshop-details-header">

    <span class="section-label">WORKSHOP</span>

    <h1>@Model.Title</h1>

    <p class="workshop-description">
        @Model.Description
    </p>

</div>

<div class="workshop-info-card">

    <div class="info-row">
        <strong>Datum</strong>
        <span>@Model.Date.ToString("dddd d MMMM yyyy")</span>
    </div>

    <div class="info-row">
        <strong>Tid</strong>
        <span>@Model.Date.ToString("HH:mm")</span>
    </div>

    <div class="info-row">
        <strong>Längd</strong>
        <span>@Model.Duration minuter</span>
    </div>

    <div class="info-row">
        <strong>Pris</strong>
        <span>@Model.Price kr</span>
    </div>

    <div class="info-row">
        <strong>Lediga platser</strong>
        <span>@availableSeats av @Model.Capacity</span>
    </div>

</div>

<div class="workshop-actions">

    @if (availableSeats > 0)
    {
        <a asp-controller="Bookings"
           asp-action="Create"
           asp-route-workshopId="@Model.Id"
           class="umi-button">
            Boka plats
        </a>
    }
    else
    {
        <p class="fully-booked">
            Denna workshop är fullbokad.
        </p>
    }

</div>