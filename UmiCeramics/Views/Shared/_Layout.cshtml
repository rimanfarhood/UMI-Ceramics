<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UmiCeramics</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UmiCeramics.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">UmiCeramics</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Workshops" asp-action="Index">
                                Paint Pottery
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">
                                Om oss
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">
                                Kontakt
                            </a>
                        </li>
                    </ul>
                </div>
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    
    <footer class="footer">

        <div class="footer-content">

            <div class="footer-brand">

                <h3>UMI Ceramics</h3>

                <p>
                    En plats för kreativitet, lugn och gemenskap.
                </p>

            </div>

            <div class="footer-links">

                <h4>Utforska</h4>

                <a asp-controller="Home" asp-action="About">About</a>

                <a asp-controller="Home" asp-action="Faq">FAQ</a>

                <a asp-controller="Home" asp-action="Events">Events</a>

                <a asp-controller="Home" asp-action="GiftCards">Gift Cards</a>

            </div>

            <div class="footer-contact">

                <h4>Kontakt</h4>

                <p>info@umiceramics.se</p>

                <p>Gävle, Sverige</p>

            </div>

        </div>

        <div class="footer-bottom">

            <a asp-controller="Home" asp-action="Privacy">
                Privacy Policy
            </a>

            <span>
                © 2026 UMI Ceramics
            </span>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
